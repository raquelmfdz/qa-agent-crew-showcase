# Copy this file to .env and fill in whichever keys you have.
# Everything here is free-tier / no-credit-card-required. The pipeline
# tries providers top to bottom (config/models.py) and falls back
# automatically if one is rate-limited, unauthorized, or unavailable.

# PRIMARY provider. Free key, no credit card:
#   1. Go to https://aistudio.google.com/app/apikey
#   2. Sign in with a Google account and click "Create API key"
GEMINI_API_KEY=

# SECONDARY / fallback provider. Free key, no credit card:
#   1. Go to https://console.groq.com/keys
#   2. Sign in and click "Create API Key"
GROQ_API_KEY=

# LAST-RESORT fallback, LOCAL RUNS ONLY (not available in GitHub Actions,
# since there's no Ollama daemon there). No key needed -- just install
# Ollama from https://ollama.com and run:
#   ollama pull llama3.1
# The factory will use it automatically if no key-based provider above
# is set, or if all key-based providers fail.
